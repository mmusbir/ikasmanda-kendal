{
  "version": 2,
  "functions": {
    "api/admin/[...all].js": {
      "maxDuration": 60
    },
    "api/[...all].js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/frontend/admin/login.html"
    },
    {
      "source": "/admin/panel",
      "destination": "/frontend/admin/dashboard.html"
    },
    {
      "source": "/direktori",
      "destination": "/frontend/direktori.html"
    },
    {
      "source": "/lapak",
      "destination": "/frontend/lapak.html"
    },
    {
      "source": "/pendaftaran",
      "destination": "/frontend/pendaftaran.html"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    }
  ]
}
